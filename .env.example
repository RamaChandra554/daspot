# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and safe for secrets.

# ─── EmailJS (for reservation confirmation emails) ─────────────────────────
# Sign up free at https://www.emailjs.com (200 emails/month on free tier)
#
# Steps:
#  1. Create an account at emailjs.com
#  2. Add an Email Service (Gmail, Outlook, etc.) → copy the Service ID
#  3. Create an Email Template with these variables:
#       {{guest_name}}       – guest's full name
#       {{guest_email}}      – guest's email address
#       {{guest_phone}}      – guest's phone number
#       {{guest_count}}      – number of guests
#       {{reservation_date}} – formatted date string (e.g. "Friday, June 6, 2025")
#       {{reservation_time}} – selected time slot (e.g. "7:00 PM")
#  4. Copy the Template ID and your account's Public Key
#  5. Paste all three values below

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
